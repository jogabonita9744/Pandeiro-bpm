<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <solid android:color="#1a3a12"/>
            <stroke android:width="5dp" android:color="#2d6b18"/>
        </shape>
    </item>
    <item android:left="16dp" android:top="16dp" android:right="16dp" android:bottom="16dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="140dp"
                android:startColor="#f8f8f4"
                android:centerColor="#f0f4e8"
                android:endColor="#d8eebc"
                android:centerX="0.38"
                android:centerY="0.32"/>
        </shape>
    </item>
    <item android:left="16dp" android:top="16dp" android:right="16dp" android:bottom="16dp">
        <shape android:shape="oval">
            <stroke android:width="1dp" android:color="#c8d8a0"/>
        </shape>
    </item>
</layer-list>
