<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <solid android:color="#1a3a12"/>
            <stroke android:width="4dp" android:color="#2d5c20"/>
        </shape>
    </item>
    <item android:left="14dp" android:top="14dp" android:right="14dp" android:bottom="14dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="110dp"
                android:startColor="#c8e6a0"
                android:centerColor="#7aad6a"
                android:endColor="#2d5c20"
                android:centerX="0.38"
                android:centerY="0.32"/>
        </shape>
    </item>
    <item android:left="14dp" android:top="14dp" android:right="14dp" android:bottom="14dp">
        <shape android:shape="oval">
            <stroke android:width="2dp" android:color="#4a7a3a"/>
        </shape>
    </item>
</layer-list>
